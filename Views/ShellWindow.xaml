<Window x:Class="TrungTamDieuHanhvaHoSo360.Views.ShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TrungTamDieuHanhvaHoSo360.Views"
        mc:Ignorable="d"
        Title="ShellWindow" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <StackPanel Background="#1F2A40">
            <TextBlock Text="📊 360° Center"
                       Foreground="White"
                       FontSize="20"
                       Margin="15"/>

            <Button Content="Dashboard" Margin="10"/>
            <Button Content="Học viên" Margin="10"/>
            <Button Content="Hồ sơ 360°" Margin="10"/>
            <Button Content="Case" Margin="10"/>
            <Button Content="Báo cáo" Margin="10"/>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

   
            <Grid Background="#2C3E50">
                <TextBlock Text="HỆ THỐNG ĐIỀU HÀNH"
                           Foreground="White"
                           VerticalAlignment="Center"
                           Margin="10"/>
            </Grid>
            <ContentControl Grid.Row="1"
                            Content="{Binding CurrentView}"/>
        </Grid>
    </Grid>
</Window>
