<UserControl x:Class="TrungTamDieuHanhVaHoSo360.Views.OperationsDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Margin="20">

            <TextBlock Text="Dashboard"
                       FontSize="22"
                       FontWeight="Bold"/>

            <!-- KPI -->
            <WrapPanel Margin="10">

                <Border Background="#3498DB" Width="180" Height="100" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Học viên" Foreground="White"/>
                        <TextBlock Text="{Binding TotalStudents}" FontSize="24" Foreground="White"/>
                    </StackPanel>
                </Border>

                <Border Background="#E67E22" Width="180" Height="100" Margin="10">
                    <StackPanel>
                        <TextBlock Text="Luận văn" Foreground="White"/>
                        <TextBlock Text="{Binding TotalThesis}" FontSize="24" Foreground="White"/>
                    </StackPanel>
                </Border>

            </WrapPanel>

            <!-- TABLE -->
            <DataGrid ItemsSource="{Binding RecentCases}" Height="250"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>