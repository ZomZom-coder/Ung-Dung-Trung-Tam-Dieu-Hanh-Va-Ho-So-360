<UserControl x:Class="TrungTamDieuHanhVaHoSo360.Views.Student360View"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>


        <StackPanel Background="#ECF0F1" Padding="10">
            <TextBlock Text="Thông tin"/>
            <TextBlock Text="{Binding Name}"/>
            <TextBlock Text="{Binding Major}"/>
        </StackPanel>

        <!-- DETAIL -->
        <TabControl Grid.Column="1">

            <TabItem Header="Học tập">
                <DataGrid ItemsSource="{Binding Scores}"/>
            </TabItem>

            <TabItem Header="Học phí">
                <DataGrid ItemsSource="{Binding Invoices}"/>
            </TabItem>

            <TabItem Header="Luận văn">
                <DataGrid ItemsSource="{Binding Thesis}"/>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>